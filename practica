function checkout() {
    if (cart.length === 0) {
        showToast("❌ Кошик порожній!");
        return;
    }

    const userName = document.getElementById("user-name") ? document.getElementById("user-name").value.trim() : "";
    const userPhone = document.getElementById("user-phone") ? document.getElementById("user-phone").value.trim() : "";

    if (!userName || !userPhone) {
        showToast("⚠️ Заповни ім'я та телефон!");
        return;
    }

    const TELEGRAM_TOKEN = '8873179905:AAFXrwvLbjoCMDHS7zxKit-JYfWjbL3fmso';
    const CHAT_ID = '1654834532';
    
    let message = `📦 *Замовлення №${orderCount}*\n`;
    message += `👤 *Клієнт:* ${userName}\n`;
    message += `📞 *Телефон:* ${userPhone}\n\n`;
    message += `🛒 *Товари:*\n`;
    
    let totalSum = 0;
    cart.forEach((item, index) => {
        const itemTotal = item.price * item.qty;
        totalSum += itemTotal;
        message += `${index + 1}. *${item.name}* — ${item.qty} шт. (${itemTotal} ₴)\n`;
    });
    
    message += `\n💰 *Загальна сума:* ${totalSum} ₴`;

    const url = `https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage`;

    fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
            chat_id: CHAT_ID,
            text: message,
            parse_mode: "Markdown" 
        })
    })
    .then(response => {
        if (response.ok) {
            showToast(`✅ Дякуємо, ${userName}! Замовлення №${orderCount} оформлено.`);
            
            if (document.getElementById("user-name")) document.getElementById("user-name").value = "";
            if (document.getElementById("user-phone")) document.getElementById("user-phone").value = "";
            
            cart = []; 
            updateCartCount(); 
            closeCartModal(); 
            orderCount++; 
        } else {
            showToast("❌ Сталася помилка при відправці.");
        }
    })
    .catch(error => {
        console.error("Помилка:", error);
        showToast("❌ Помилка мережі.");
    });
}

function showToast(text) {
    let container = document.getElementById("toast-container");
    
    if (!container) {
        container = document.createElement("div");
        container.id = "toast-container";
        container.className = "toast-container";
        document.body.appendChild(container);
    }
    
    const toast = document.createElement("div");
    toast.className = "toast";
    toast.innerText = text;
    
    container.appendChild(toast);
    
    setTimeout(() => {
        toast.remove();
    }, 3000);
}
