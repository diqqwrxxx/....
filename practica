<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scorpio</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<header class="top-bar">
    <div class="logo">
        <img src="logo.png" alt="Scorpio Логотип">
    </div>

    <div class="catalog-container">
        <button class="catalog-btn" id="catalog-trigger">
            <span>▦</span> Всі товари <span id="arrow">▼</span>
        </button>
        <div class="dropdown-menu" id="dropdown-menu">
            <button onclick="filterByCategory('all')">Всі товари</button>
            <button onclick="filterByCategory('фрукти')">Фрукти</button>
            <button onclick="filterByCategory('овочі')">Овочі</button>
            <button onclick="filterByCategory('молочка')">Молочка</button>
            <button onclick="filterByCategory('м\'ясо')">М'ясо</button>
            <button onclick="filterByCategory('хліб')">Хліб</button>
            <button onclick="filterByCategory('напої')">Напої</button>
            <button onclick="filterByCategory('Алкоголь')">Алкоголь</button>
            <button onclick="filterByCategory('Комбо')">Комбо</button>
            <button onclick="filterByCategory('Сир')">Сир</button>
        </div>
    </div>

    <div class="search-container">
        <input type="text" id="search" placeholder="Я шукаю..." onkeyup="searchItems()">
    </div>

    <button id="theme-toggle" class="theme-btn" style="margin-right: 15px;">🌙</button>

    <div class="header-cart" onclick="openCartModal()">
        🛒 Кошик: <span id="cart-count">0</span>
    </div>
</header>

<main>
    <section id="products" class="grid"></section>
    <div id="pagination" class="pagination"></div>
</main>

<div id="cart-modal" class="modal">
    <div class="modal-content">
        <span class="close-btn" onclick="closeCartModal()">&times;</span>
        <h2>🛒 Ваш кошик</h2>
        
        <div id="cart-items-list"></div>
        
        <div class="cart-total-block">
            <h3>Разом: <span id="cart-total-price">0</span> ₴</h3>
            
            <div class="order-form">
                <input type="text" id="user-name" placeholder="Твоє ім'я">
                <input type="text" id="user-phone" placeholder="Номер телефону">
            </div>
            
            <button class="buy-btn-orange" onclick="checkout()">Оформити замовлення</button>
        </div>
    </div>
</div>

<div id="toast-container" class="toast-container"></div>

<script src="script.js"></script>
</body>
</html>




* { 
    margin: 0; 
    padding: 0; 
    box-sizing: border-box; 
}

body { 
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
    background: #f4f7f5; /* Свіжий, злегка зеленкуватий світлий фон */
    color: #1a241f; /* Глибокий темний колір з зеленим відтінком */
    transition: background-color 0.3s, color 0.3s;
}

.top-bar {
    background: #ffffff; 
    padding: 15px 5%; 
    display: flex;
    align-items: center; 
    justify-content: space-between;
    position: sticky; 
    top: 0; 
    z-index: 1000;
    box-shadow: 0 4px 20px rgba(26, 36, 31, 0.04); 
}

.logo img { 
    height: 45px; 
    object-fit: contain;
}

.catalog-container { position: relative; }
.catalog-btn {
    background: #ffffff; 
    border: 2px solid #10b981; /* Смарагдово-зелений */
    color: #10b981;
    padding: 10px 22px; 
    border-radius: 25px; 
    font-weight: 600; 
    cursor: pointer;
    transition: all 0.2s ease;
}
.catalog-btn:hover {
    background: #10b981;
    color: #ffffff;
}

/* Випадаюче меню каталогу */
.dropdown-menu {
    display: none; 
    position: absolute; 
    top: 60px; 
    left: 0;
    background: #ffffff; 
    width: 220px; 
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    border-radius: 16px; 
    padding: 8px; 
    z-index: 2000; 
    flex-direction: column;
    border: 1px solid #e6eee9;
}
.dropdown-menu.show { display: flex; }
.dropdown-menu button {
    background: none; 
    border: none; 
    text-align: left; 
    padding: 10px 14px;
    cursor: pointer; 
    border-radius: 8px;
    font-size: 0.95rem;
    color: #2d3a34;
    transition: all 0.2s;
}
.dropdown-menu button:hover { 
    background: #e6f7f0; 
    color: #10b981; 
    font-weight: 600;
}

.search-container { flex: 1; display: flex; justify-content: center; margin: 0 30px; }
#search {
    width: 100%; 
    max-width: 500px; 
    padding: 12px 24px;
    border-radius: 25px; 
    border: 1px solid #ccdcd2; 
    background: #edf3f0;
    color: #1a241f;
    font-size: 0.95rem;
    transition: all 0.2s;
}
#search:focus {
    background: #ffffff;
    border-color: #10b981;
    outline: none;
    box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15);
}

.header-cart {
    background: #e6f7f0; 
    color: #10b981; 
    padding: 10px 22px;
    border-radius: 25px; 
    border: 2px solid #10b981; 
    font-weight: bold; 
    cursor: pointer;
    transition: all 0.2s ease;
}
.header-cart:hover {
    background: #10b981;
    color: #ffffff;
}

.grid {
    display: grid; 
    grid-template-columns: repeat(6, 1fr);
    gap: 24px; 
    padding: 40px 5%;
}

.product-card {
    background: #ffffff;
    padding: 20px;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.01);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column; 
    justify-content: space-between; 
    height: 100%; 
    border: 1px solid #e6eee9;
}
.product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 25px rgba(26, 36, 31, 0.06);
}

.product-card h3 {
    margin: 12px 0;
    font-size: 1rem;
    font-weight: 600;
    color: #2d3a34;
    min-height: 3.6em; 
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.product-card img {
    width: 100%;
    height: 160px;
    object-fit: contain;
    margin-bottom: 12px;
}

.buy-btn-orange {
    background: #10b981; 
    color: white; 
    border: none; 
    padding: 12px;
    border-radius: 25px; 
    width: 100%; 
    cursor: pointer; 
    font-weight: bold;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
}
.buy-btn-orange:hover {
    background: #059669;
    box-shadow: 0 6px 18px rgba(16, 185, 129, 0.35);
}

.pagination { display: flex; justify-content: center; gap: 12px; padding: 40px 0; }
.page-btn {
    width: 42px; 
    height: 42px; 
    border: 1px solid #d1ded6; 
    background: white;
    border-radius: 50%; 
    cursor: pointer; 
    font-weight: bold;
    color: #495057;
    transition: all 0.2s;
}
.page-btn:hover {
    border-color: #10b981;
    color: #10b981;
}
.page-btn.active { 
    background: #10b981; 
    color: white; 
    border-color: #10b981; 
    box-shadow: 0 4px 10px rgba(16, 185, 129, 0.25);
}

.modal {
    display: none; 
    position: fixed; 
    z-index: 3000; 
    left: 0; 
    top: 0;
    width: 100%; 
    height: 100%; 
    background: rgba(18, 28, 23, 0.5); 
    backdrop-filter: blur(4px);
    align-items: center; 
    justify-content: center;
}

.modal-content {
    background: #ffffff; 
    margin: 5% auto; 
    padding: 30px; 
    width: 460px; 
    max-height: 85vh; 
    border-radius: 24px; 
    position: relative;
    display: flex;
    flex-direction: column; 
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
}

.close-btn { 
    position: absolute; 
    right: 22px; 
    top: 20px; 
    font-size: 28px; 
    cursor: pointer; 
    color: #94a3b8;
    transition: color 0.2s;
    z-index: 10; 
}
.close-btn:hover { color: #10b981; }


#cart-items-list {
    flex: 1; 
    overflow-y: auto; 
    margin-top: 20px;
    padding-right: 8px; 
}


#cart-items-list::-webkit-scrollbar { width: 6px; }
#cart-items-list::-webkit-scrollbar-track { background: transparent; }
#cart-items-list::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

/* Блок з інпутами та кнопкою замовлення */
.cart-total-block {
    margin-top: auto; 
    padding-top: 20px;
    border-top: 1px solid #e6eee9; 
    background: inherit; 
}

.cart-total-block h3 {
    font-size: 1.25rem;
    margin-bottom: 15px;
    color: #1a241f;
}

/* Форма вводу */
.order-form {
    margin-bottom: 15px;
    display: flex;
    flex-direction: column;
    gap: 12px; 
}

.order-form input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #ccdcd2; 
    border-radius: 12px; 
    background-color: #f4f7f5; 
    color: #1a241f;
    font-size: 0.95rem;
    box-sizing: border-box;
    transition: all 0.2s;
}
.order-form input:focus {
    border-color: #10b981; 
    background-color: #ffffff;
    outline: none;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
}

#cart-items-list button {
    background: #10b981;
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: bold;
    padding: 5px 10px;
    cursor: pointer;
    transition: background 0.2s;
}
#cart-items-list button:hover { background: #059669; }

.theme-btn {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    border: 2px solid #10b981; 
    background: #e6f7f0; 
    color: #10b981;
    font-size: 1.3rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
}
.theme-btn:hover {
    transform: scale(1.05);
}

body.dark-mode {
    background-color: #090d0b !important; 
    color: #c2d1c9 !important; 
}

.dark-mode .top-bar, 
.dark-mode .product-card, 
.dark-mode .modal-content, 
.dark-mode .dropdown-menu {
    background-color: #111815 !important; 
    color: #f4f7f5 !important;
    border: 1px solid #1d2a23 !important; 
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4) !important;
}

.dark-mode .product-card h3 { color: #ecf3f0 !important; }
.dark-mode .cart-total-block h3 { color: #ffffff !important; }
.dark-mode .cart-total-block { border-top-color: #1d2a23 !important; }

.dark-mode #search {
    background-color: #090d0b !important;
    color: #ffffff !important;
    border: 1px solid #1d2a23 !important;
}
.dark-mode #search:focus {
    border-color: #059669 !important;
    box-shadow: 0 0 0 4px rgba(5, 150, 105, 0.2) !important;
}

.dark-mode .page-btn {
    background-color: #111815 !important;
    color: #7c9386;
    border-color: #1d2a23 !important;
}
.dark-mode .page-btn:hover { color: #10b981; border-color: #10b981; }
.dark-mode .page-btn.active {
    background-color: #10b981 !important; 
    color: white !important;
    border-color: #10b981 !important;
    box-shadow: 0 0 15px rgba(16, 185, 129, 0.4) !important;
}

.dark-mode .buy-btn-orange {
    background: linear-gradient(135deg, #10b981, #047857) !important; 
    border: none !important;
    box-shadow: 0 4px 14px rgba(4, 120, 87, 0.4) !important;
}
.dark-mode .buy-btn-orange:hover {
    background: linear-gradient(135deg, #059669, #065f46) !important;
}

.dark-mode #cart-items-list button { background: #10b981 !important; }
.dark-mode #cart-items-list button:hover { background: #059669 !important; }

.dark-mode .catalog-btn { border-color: #10b981; color: #10b981; background: transparent; }
.dark-mode .catalog-btn:hover { background: #10b981; color: white; }
.dark-mode .dropdown-menu button { color: #7c9386; }
.dark-mode .dropdown-menu button:hover { background: #1d2a23; color: #10b981; }

.dark-mode .header-cart {
    background: #1d2a23 !important;
    color: #10b981 !important;
    border-color: #10b981 !important;
}
.dark-mode .header-cart:hover {
    background: #10b981 !important;
    color: #ffffff !important;
}

.dark-mode .theme-btn {
    background-color: #111815;
    border-color: #10b981;
    color: #f1c40f;
}

.dark-mode .order-form input {
    background-color: #090d0b !important;
    color: #ffffff !important;
    border: 1px solid #1d2a23 !important;
}
.dark-mode .order-form input:focus {
    border-color: #10b981 !important;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15) !important;
}


.toast-container {
    position: fixed;
    bottom: 25px;
    right: 25px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.toast {
    background: #10b981;
    color: white;
    padding: 16px 28px;
    border-radius: 14px;
    font-weight: 600;
    font-size: 0.95rem;
    box-shadow: 0 10px 25px rgba(16, 185, 129, 0.25);
    display: flex;
    align-items: center;
    gap: 8px;
    animation: slideIn 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.dark-mode .toast {
    background: linear-gradient(135deg, #10b981, #047857);
    box-shadow: 0 10px 25px rgba(4, 120, 87, 0.3);
}

@keyframes slideIn {
    from { transform: translateX(120%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
}
.logo img { 
    height: 45px; 
    width: auto;  
    object-fit: contain;
    display: block;
}



